[Unit]
Description=Mirror Deployer Next.js server
After=network.target

[Service]
Type=simple
User=yojinbot
WorkingDirectory=/home/yojinbot/mirror-deployer
Environment=NODE_ENV=production
Environment=PORT=3032
Environment=HOSTNAME=127.0.0.1
EnvironmentFile=/home/yojinbot/mirror-deployer/.env.local
ExecStart=/usr/bin/node server.js
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=mirror-deployer

[Install]
WantedBy=multi-user.target
